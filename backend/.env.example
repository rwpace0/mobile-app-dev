# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# Found in Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Public URL for your R2 bucket (custom domain or the r2.dev subdomain)
R2_PUBLIC_URL=https://your-bucket.your-domain.com

# ─── CORS Origins ────────────────────────────────────────────────────────────
# URL of the frontend (used for web/production CORS)
FRONTEND_URL=http://localhost:8081
# Backend's own URL (used as a fallback CORS origin)
BACKEND_URL=http://localhost:3000
# Local network IP for iOS Expo Go (e.g. http://192.168.x.x:3000)
IOS=http://192.168.1.85:3000

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
