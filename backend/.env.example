# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# Found in Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Public URL for your R2 bucket (custom domain or the r2.dev subdomain)
R2_PUBLIC_URL=https://your-bucket.your-domain.com

# ─── Dev (single IP for all dev URLs) ─────────────────────────────────────────
# Your machine's local IP. Used to build: CORS origins (frontend + backend), Expo email links (exp://IP:8081).
# Get it with: ipconfig (Windows) or ifconfig (Mac/Linux). Update when you change networks.
DEV_HOST=192.168.1.85

# Production CORS origin (optional). Set when deploying so the backend allows your production frontend.
# FRONTEND_URL=https://your-app.com

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
