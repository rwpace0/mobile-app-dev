# ─── Backend API URL ─────────────────────────────────────────────────────────
# Used for Android, web, and production builds
# Development:  http://192.168.x.x:3000  (your local network IP)
# Production:   https://your-api-domain.com
BACKEND_URL=http://192.168.1.85:3000

# iOS-specific URL for Expo Go on a physical device
# Must be your local network IP (localhost won't work on a real device)
IOS=http://192.168.1.85:3000

# Local network IP used for deep-link prefixes in development
EXPO_PUBLIC_DEV_IP=192.168.1.85
