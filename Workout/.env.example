# ─── Dev (single IP for all dev URLs) ─────────────────────────────────────────
# Your machine's local IP. Used to build: API URL (http://IP:3000), deep links (exp://IP:8081).
# Get it with: ipconfig (Windows) or ifconfig (Mac/Linux). Update when you change networks.
DEV_HOST=192.168.1.85

# ─── Production API URL ──────────────────────────────────────────────────────
# Used for release builds. Development uses http://DEV_HOST:3000.
BACKEND_URL=https://your-api-domain.com
